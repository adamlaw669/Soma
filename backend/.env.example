# Environment variables for Render deployment

# Model path (optional, defaults to app/models/soma_model_v1.joblib)
# MODEL_PATH=/opt/render/project/src/app/models/soma_model_v1.joblib

# Disable SQLite usage in dependencies
SQLALCHEMY_SILENCE_UBER_WARNING=1
SHAP_PLOTS_DISABLE=1

# Use memory or temp storage instead of SQLite
TRANSFORMERS_CACHE=/tmp/transformers_cache
HF_HOME=/tmp/huggingface

# Example environment configuration for Soma Backend

# Database Configuration
DATABASE_URL=sqlite:///./soma.db

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,https://somahealth.vercel.app

# Security
# A strong, random secret key required to access the doctor review portal.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DOCTOR_API_KEY=change-me-to-a-strong-random-secret

# External Services
# OPENAI_API_KEY=your-openai-key
# SENDGRID_API_KEY=your-sendgrid-key

# Deployment
# PORT=8000
# HOST=0.0.0.0
# WORKERS=4

